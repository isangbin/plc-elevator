<Window x:Class="Elevator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Elevator WPF HMI" Height="750" Width="1300" Background="#1A1C20">

    <Window.Resources>
        <Style x:Key="ElevatorButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2D3035"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="4"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                            Background="{TemplateBinding Background}" 
                            CornerRadius="4" 
                            BorderBrush="#40444B" 
                            BorderThickness="1.5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3E4451"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#43B581"/>
                            </Trigger>

                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding Background, RelativeSource={RelativeSource Self}}" Value="Orange"/>
                                    <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True"/>
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="#FFB74D"/>
                            </MultiDataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#23272E" CornerRadius="12" BorderBrush="#36393F" BorderThickness="1" Margin="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="15,0">
                    <Border Background="#2F3136" Margin="0,8" Padding="10" CornerRadius="5">
                        <StackPanel>
                            <TextBlock Text="4F" Foreground="Gray" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                            <Button x:Name= "Outer_4D" Content="↓" Style="{StaticResource ElevatorButtonStyle}" Height="50" Foreground="#F04747" Tag="4D" Click="CallButton_Click"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#2F3136" Margin="0,8" Padding="10" CornerRadius="5">
                        <StackPanel>
                            <TextBlock Text="3F" Foreground="Gray" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                            <UniformGrid Columns="2">
                                <Button x:Name= "Outer_3U" Content="↑" Style="{StaticResource ElevatorButtonStyle}" Height="50" Foreground="#43B581" Tag="3U" Click="CallButton_Click"/>
                                <Button x:Name= "Outer_3D" Content="↓" Style="{StaticResource ElevatorButtonStyle}" Height="50" Foreground="#F04747" Tag="3D" Click="CallButton_Click"/>
                            </UniformGrid>
                        </StackPanel>
                    </Border>
                    <Border Background="#2F3136" Margin="0,8" Padding="10" CornerRadius="5">
                        <StackPanel>
                            <TextBlock Text="2F" Foreground="Gray" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                            <UniformGrid Columns="2">
                                <Button x:Name= "Outer_2U" Content="↑" Style="{StaticResource ElevatorButtonStyle}" Height="50" Foreground="#43B581" Tag="2U" Click="CallButton_Click"/>
                                <Button x:Name= "Outer_2D" Content="↓" Style="{StaticResource ElevatorButtonStyle}" Height="50" Foreground="#F04747" Tag="2D" Click="CallButton_Click"/>
                            </UniformGrid>
                        </StackPanel>
                    </Border>
                    <Border Background="#2F3136" Margin="0,8" Padding="10" CornerRadius="5">
                        <StackPanel>
                            <TextBlock Text="1F" Foreground="Gray" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                            <Button x:Name="Outer_1U" Content="↑" Style="{StaticResource ElevatorButtonStyle}" Height="50" Foreground="#43B581" Tag="1U" Click="CallButton_Click"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Canvas Grid.Column="1" x:Name="ShaftCanvas" ClipToBounds="True">
                    <Path Stroke="#3E4451" StrokeThickness="2" Data="M60,50 V600 H380 V50 M60,187.5 H380 M60,325 H380 M60,462.5 H380"/>
                    <Rectangle Width="6" Height="550" Fill="#18191C" Canvas.Left="215" Canvas.Top="50"/>

                    <TextBlock Text="4" Canvas.Right="80" Canvas.Top="105" Foreground="#8E9297" FontSize="18"/>
                    <TextBlock Text="3" Canvas.Right="80" Canvas.Top="242" Foreground="#8E9297" FontSize="18"/>
                    <TextBlock Text="2" Canvas.Right="80" Canvas.Top="380" Foreground="#8E9297" FontSize="18"/>
                    <TextBlock Text="1" Canvas.Right="80" Canvas.Top="517" Foreground="#8E9297" FontSize="18"/>

                    <Border x:Name="ElevatorCar" Width="120" Height="90" Background="White" CornerRadius="5" Canvas.Left="158" Canvas.Bottom="72">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.4"/>
                        </Border.Effect>
                        <StackPanel VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock x:Name="TxtSmallFloor" Text="1F" Foreground="#23272E" FontWeight="Bold" FontSize="16"/>
                                <!--<TextBlock x:Name="TxtSmallDir" Text="↑" Foreground="#43B581" FontSize="16" Margin="5,0,0,0"/>-->
                            </StackPanel>
                            <Rectangle Width="80" Height="45" Fill="#D1D3D8" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                </Canvas>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="#23272E" CornerRadius="12" BorderBrush="#36393F" BorderThickness="1" Margin="10">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="40"/>
                </Grid.RowDefinitions>

                <Border Grid.Column="1" Grid.Row="0" Background="#18191C" CornerRadius="5" Margin="20,20,20,10" Height="65" BorderBrush="#43B581" BorderThickness="1.2" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="30,0">
                        <TextBlock x:Name="Text_InnerFloor" Text="1F" Foreground="#43B581" FontSize="35" FontWeight="Bold" FontFamily="Segoe UI Black"/>
                        <TextBlock x:Name="Text_InnerDir" Text="　" Foreground="#43B581" FontSize="35" Margin="15,0,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Grid.Row="1" Background="#2F3136" BorderBrush="Black" BorderThickness="4" Margin="10,0,10,20">
                    <Grid x:Name="DoorContainer">
                        <Rectangle x:Name="DoorLeft" Fill="#72767D" HorizontalAlignment="Left" Width="140" Margin="1,0" Stroke="Black">
                            <Rectangle.RenderTransform>
                                <TranslateTransform x:Name="LeftDoorTransform"/>
                            </Rectangle.RenderTransform>
                        </Rectangle>
                        <Rectangle x:Name="DoorRight" Fill="#72767D" HorizontalAlignment="Right" Width="140" Margin="1,0" Stroke="Black">
                            <Rectangle.RenderTransform>
                                <TranslateTransform x:Name="RightDoorTransform"/>
                            </Rectangle.RenderTransform>
                        </Rectangle>
                        <!--<Rectangle Width="2" Fill="Black" HorizontalAlignment="Center"/>-->
                    </Grid>
                </Border>

                <Border Grid.Column="2" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <UniformGrid Columns="2" Width="140">
                        <Button x:Name= "Inner_3" Content="3" Style="{StaticResource ElevatorButtonStyle}" Height="60" Width="65" Click="InnerButton_Click" Tag="3"/>
                        <Button x:Name= "Inner_4" Content="4" Style="{StaticResource ElevatorButtonStyle}" Height="60" Width="65" Click="InnerButton_Click" Tag="4"/>
                        <Button x:Name= "Inner_1" Content="1" Style="{StaticResource ElevatorButtonStyle}" Height="60" Click="InnerButton_Click" Tag="1" Margin="4,0,1,0"/>
                        <Button x:Name= "Inner_2" Content="2" Style="{StaticResource ElevatorButtonStyle}" Height="60" Width="65" Click="InnerButton_Click" Tag="2"/>
                        <Button x:Name= "PushOpen" Content="&lt; &gt;" Style="{StaticResource ElevatorButtonStyle}" Height="60" Width="65" Click="InnerButton_Click" Tag="Open"/>
                        <Button x:Name= "PushClose" Content="&gt; &lt;" Style="{StaticResource ElevatorButtonStyle}" Height="60" Width="65" Click="InnerButton_Click" Tag="Close"/>
                        <Button Content="SOS" Style="{StaticResource ElevatorButtonStyle}" Background="#F04747" Height="60" Width="65" Click="InnerButton_Click" Tag="Emergency"/>
                        <Button Content="Svc" Style="{StaticResource ElevatorButtonStyle}" Height="60" Width="65" Click="InnerButton_Click" Tag="Service"/>
                    </UniformGrid>
                </Border>

                <TextBlock Grid.ColumnSpan="3" Grid.Row="2" Text="PLC 통신 상태: 정상 [XG5000: 0.1s update]" 
                           Foreground="#72767D" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>